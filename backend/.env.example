# Template for required environment variables.
# Copy this file to .env and fill in your real values:
#   cp .env.example .env
# Get an API key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-new-key-here

# Browserbase (search + page fetch + headless-browser fallback).
# API key: https://www.browserbase.com/dashboard  (Settings -> API Keys)
BROWSERBASE_API_KEY=bb_live_your-key-here
# Project ID is required for the headless session fallback in /api/fetch-markdown.
BROWSERBASE_PROJECT_ID=your-project-id-here

# Redis (post storage / caching).
REDIS_URL=redis://localhost:6379
