# Template for required environment variables.
# Copy this file to .env and fill in your real values:
#   cp .env.example .env

# Anthropic Claude API — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Redis Cloud (free tier) — https://app.redislabs.com → Create Database → Security tab
# Format: redis://default:<password>@<public-endpoint-host>:<port>
REDIS_URL=redis://default:your-password@your-host.redis.cloud:port

# Browserbase (for fetch-markdown and related-links)
BROWSERBASE_API_KEY=bb_live_your-key-here
